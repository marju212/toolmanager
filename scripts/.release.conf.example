# .release.conf — Configuration for release.sh and deploy.sh
#
# Place this file in your repository root as .release.conf.
# Values can also be set via environment variables (which take highest priority).
#
# Config priority (later wins):
#   1. <repo>/.release.conf   (repo-level)
#   2. --config FILE           (explicit flag)
#   3. Environment variables   (highest priority)

# Branch to release from. Default: main
# Env var: RELEASE_DEFAULT_BRANCH
# DEFAULT_BRANCH=main

# Prefix for version tags (e.g. "v" produces tags like v1.2.3). Default: v
# Env var: RELEASE_TAG_PREFIX
# TAG_PREFIX=v

# Git remote name. Default: origin
# Env var: RELEASE_REMOTE
# REMOTE=origin

# Path to the tools.json manifest. Defaults to tools.json in the working
# directory if unset. Set this if your manifest lives elsewhere.
# Env var: TOOLS_MANIFEST
# TOOLS_MANIFEST=/etc/toolmanager/tools.json

# Path to a custom modulefile template file. Supports placeholders:
# %VERSION%, %ROOT%, %TOOL_NAME%, %DEPLOY_BASE_PATH%
# For toolsets: %<tool-name>% (per-tool version), %TOOL_LOADS% (auto module loads)
# Env var: MODULEFILE_TEMPLATE
# MODULEFILE_TEMPLATE=/opt/templates/my-tool.tcl

# Separate template for toolset modulefiles. If unset, toolsets use
# MODULEFILE_TEMPLATE, falling back to the built-in default.
# Env var: TOOLSET_MODULEFILE_TEMPLATE
# TOOLSET_MODULEFILE_TEMPLATE=/opt/templates/toolset.tcl

# Override the base directory for modulefiles.
# If unset, modulefiles are written to deploy_base_path/mf/<tool>/<version>.
# If set, modulefiles are written to MF_BASE_PATH/<tool>/<version>.
# Useful when modulefiles live on a separate mount (e.g. a shared NFS path).
# Env var: MF_BASE_PATH
# MF_BASE_PATH=/opt/modulefiles
