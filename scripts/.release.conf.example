# .release.conf — Configuration for release.sh, deploy.sh, and bundle.sh
#
# Place this file in your repository root as .release.conf or in your
# home directory as ~/.release.conf. Values can also be set via
# environment variables (which take highest priority).
#
# Config priority (later wins):
#   1. ~/.release.conf        (user-level)
#   2. <repo>/.release.conf   (repo-level)
#   3. --config FILE           (explicit flag)
#   4. Environment variables   (highest priority)

# GitLab personal access token (required for API calls).
# Needs api scope. Token is resolved in this order:
#   1. GITLAB_TOKEN environment variable  (export GITLAB_TOKEN=glpat-...)
#   2. GITLAB_TOKEN key in a .release.conf file
#   3. ~/.gitlab_token plain-text file    (echo "glpat-..." > ~/.gitlab_token)
# Prefer option 1 or 3 over committing a token to a config file.
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab API base URL. Change this for self-hosted GitLab instances.
# Env var: GITLAB_API_URL
GITLAB_API_URL=https://gitlab.com/api/v4

# Branch to release from.
# Env var: RELEASE_DEFAULT_BRANCH
DEFAULT_BRANCH=main

# Prefix for version tags (e.g. "v" produces tags like v1.2.3).
# Env var: RELEASE_TAG_PREFIX
TAG_PREFIX=v

# Git remote name.
# Env var: RELEASE_REMOTE
REMOTE=origin

# Verify SSL certificates. Set to false for self-hosted GitLab with
# self-signed certificates.
# Env var: GITLAB_VERIFY_SSL
VERIFY_SSL=true

# Update the GitLab default branch to the release branch after a release.
# Set to false to skip this step entirely. When true, the script prompts
# for confirmation (auto-accepted in --non-interactive mode).
# Env var: RELEASE_UPDATE_DEFAULT_BRANCH
UPDATE_DEFAULT_BRANCH=true

# Base path for deploy (clone + modulefile). If unset, deploy is skipped.
# The deploy step clones into DEPLOY_BASE_PATH/<tool>/<version> and writes
# a modulefile to DEPLOY_BASE_PATH/mf/<tool>/<version>.
# Env var: DEPLOY_BASE_PATH
# DEPLOY_BASE_PATH=/opt/software

# Path to a custom modulefile template file. Supports placeholders:
# %VERSION%, %ROOT%, %TOOL_NAME%, %DEPLOY_BASE_PATH%
# For bundles: %tool-name% (per-tool version), %TOOL_LOADS% (auto module loads)
# Env var: MODULEFILE_TEMPLATE
# MODULEFILE_TEMPLATE=/opt/templates/my-tool.tcl

# ── Bundle-specific settings (toolset repos with submodules) ──────────

# Subdirectory containing tool submodules. If unset, scans repo root.
# Env var: BUNDLE_SUBMODULE_DIR
# BUNDLE_SUBMODULE_DIR=tools

# Override the bundle name (defaults to repo name from git remote).
# Env var: BUNDLE_NAME
# BUNDLE_NAME=my-toolset
